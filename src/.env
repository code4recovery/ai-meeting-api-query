# Google Gemini
GEMINI_API_KEY=YOUR_API_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# MongoDB Atlas
MONGODB_URI=mongodb://matthew_db_user:LSvaM1l2DAz0pfBU@ac-glsfya1-shard-00-02.sqnbidl.mongodb.net:27017,ac-glsfya1-shard-00-00.sqnbidl.mongodb.net:27017,ac-glsfya1-shard-00-01.sqnbidl.mongodb.net:27017/?appName=Cluster0&ssl=true&authSource=admin
MONGODB_DB=aa_meetings
MONGODB_COLLECTION=meetings

# Vector Search
VECTOR_INDEX_NAME=aa_meetings_vector_index
